{
  "name": "tinyfy-editor-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "echo '[workspace:@i-prikot/playground] dev' && npm run dev --workspace=@i-prikot/playground",
    "build": "echo '[workspace:@i-prikot/editor-schema] build' && npm run build --workspace=@i-prikot/editor-schema && echo '[workspace:@i-prikot/editor] build' && npm run build --workspace=@i-prikot/editor && echo '[workspace:@i-prikot/renderer] build' && npm run build --workspace=@i-prikot/renderer && echo '[workspace:@i-prikot/playground] build' && npm run build --workspace=@i-prikot/playground",
    "typecheck": "echo '[workspace] typecheck' && vue-tsc --build",
    "lint": "npm run lint --workspaces --if-present && eslint test e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "node scripts/prepare-husky.cjs",
    "precommit": "lint-staged --concurrent 1 && npm run typecheck",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "happy-dom": "20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "15.5.2",
    "prettier": "^3.9.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  },
  "overrides": {
    "glob": "13.0.6"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
