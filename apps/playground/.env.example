# Tiptap playground/demo app environment
#
# These VITE_TIPTAP_* variables are актуальны для playground/demo app only.
# The reusable editor library must not read import.meta.env directly; pass
# configuration into the library boundary via props/options instead.
#
# Copy this file to .env for local development. Keep long-lived production
# secrets out of frontend builds, because Vite exposes VITE_* values to clients.

# Collaboration (Tiptap Cloud)
# Set an app id to enable collaboration in the playground/demo runtime.
VITE_TIPTAP_COLLAB_APP_ID=

# Endpoint used to request short-lived collaboration JWTs.
VITE_TIPTAP_COLLAB_TOKEN_URL=/api/collaboration

# Static collaboration JWT for local development only. Leave blank in commits
# and prefer VITE_TIPTAP_COLLAB_TOKEN_URL for real environments.
VITE_TIPTAP_COLLAB_TOKEN=

# Optional prefix for URL-derived collaboration document names.
VITE_TIPTAP_COLLAB_DOC_PREFIX=

# AI (Tiptap Cloud)
# Set an app id to mark the playground/demo AI flow as configured.
VITE_TIPTAP_AI_APP_ID=

# Endpoint used to request short-lived AI JWTs.
VITE_TIPTAP_AI_TOKEN_URL=/api/ai
